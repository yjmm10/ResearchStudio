# IdeaSpark — environment variable template
#
# Copy this file to .env and fill in your values. .env is gitignored;
# this template is committed so others know which env vars to set.
#
#   cp .env.template .env
#   # then edit .env with your real values
#   set -a; source .env; set +a   # load into current shell

# ----- Required for the Phase 0 + Phase 3.1 literature connectors -----

# OpenReview connector — needed to retrieve in-review submissions
OPENREVIEW_USER=your_openreview_email@example.com
OPENREVIEW_PASS=your_openreview_password


# ----- Optional but recommended -----

# OpenAlex polite-pool: real email in User-Agent gets 10 req/s vs 1 anonymous.
# Not authentication; just friendly identification per OpenAlex API guidelines.
# OpenAlex premium API key (higher rate; optional, polite-pool also works without).
OPENALEX_MAILTO=your_email@example.com
OPENALEX_API_KEY=your_openalex_key

# Semantic Scholar API key (higher rate limits; the connector also works anonymously).
SEMANTICSCHOLAR_API_KEY=your_semanticscholar_key

# ScraperAPI key for the Google Scholar connector proxy (paper-search).
# Optional — without it, the Google Scholar connector simply runs without a proxy.
SCRAPER_API_KEY=your_scraperapi_key

# Exa search API key (paper-search exa connector — required to use that connector).
EXA_API_KEY=your_exa_key

# DeepXiv token (paper-search deepxiv connector — OPTIONAL).
# A few free queries ("transformer", "attention mechanism", "large language model") work
# without a token; set this for all other queries. 10,000 free requests/day.
DEEPXIV_TOKEN=your_deepxiv_token

# Sciverse API token (paper-search sciverse connector — REQUIRED to use that connector).
# Starts with "sv-". Get one at https://sciverse.space/tokens
SCIVERSE_API_TOKEN=sv-your_sciverse_token
